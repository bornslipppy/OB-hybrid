# Python / uv
__pycache__/
*.pyc
*.pyo
.python-version   # uv python pin
.venv/
.env

# Raw handover notes (h2 pull / profiles) — keep out of git.
h2/data/raw/
h2/data/*.pii
h2/data/*.raw
profiles/raw/
*.handover.txt
*.handover_raw.*

# PII spreadsheets (sales-notes / handover exports) — never auto-stage these.
# The existing Tamar export is already tracked on private ob-brain clones; these
# rules block any NEW or re-exported PII workbook from being added accidentally.
# To add an intended export to a private clone, force it: `git add -f <file>`.
data/*.xlsx
data/*.xls
data/*.csv
*Notes-for-*
*sales-notes*

# Campaign run outputs are tracked for private ob-brain clones (reproducible eval artifacts).
# proto-manifest remains the canonical freeze stub for dry-runs.

# Scaffold dirs: track the .gitkeep placeholder, ignore generated content.
runs/*
!runs/.gitkeep
reports/*
!reports/.gitkeep

# Secrets / API keys
.env.local
.env.*.local
secrets/

# macOS / IDE
.DS_Store
.idea/
.vscode/
*.swp

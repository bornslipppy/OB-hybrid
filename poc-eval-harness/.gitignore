# Scaffold dirs: track the .gitkeep placeholder, ignore generated content.
runs/*
!runs/.gitkeep
reports/*
!reports/.gitkeep

# Secrets / API keys
.env.local
.env.*.local
secrets/

# macOS / IDE
.DS_Store
.idea/
.vscode/
*.swp

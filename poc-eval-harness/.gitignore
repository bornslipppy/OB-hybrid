# Python / uv
__pycache__/
*.pyc
*.pyo
.python-version   # uv python pin
.venv/
.env

# Raw handover notes — NEVER committed (D-8 / NFR-3).
# Raw notes live outside the repo under access control (architecture §8).
h2/data/raw/
h2/data/*.pii
h2/data/*.raw
profiles/raw/
*.handover.txt
*.handover_raw.*
data/*.xlsx
data/*.xls

# Campaign run outputs are tracked for private ob-brain clones (reproducible eval artifacts).
# proto-manifest remains the canonical freeze stub for dry-runs.

# Scaffold dirs: track the .gitkeep placeholder, ignore generated content.
runs/*
!runs/.gitkeep
reports/*
!reports/.gitkeep

# Secrets / API keys
.env.local
.env.*.local
secrets/

# macOS / IDE
.DS_Store
.idea/
.vscode/
*.swp
